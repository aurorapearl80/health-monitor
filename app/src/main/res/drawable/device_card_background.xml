<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Light gray/white background for dark theme -->
    <solid android:color="#2A2A2A" />

    <!-- Subtle border -->
    <stroke
        android:width="1dp"
        android:color="#404040" />

    <!-- Rounded corners -->
    <corners android:radius="12dp" />

    <!-- Optional: padding effect -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />

</shape>