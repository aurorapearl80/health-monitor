<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="16dp"
    android:gravity="center">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/heart_rate_line"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/fall" />

    <!-- Dialog Message -->
    <TextView
        android:id="@+id/dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="We detected you may have fell or requested Emergency Call?"
        android:textSize="14sp"
        android:textColor="@color/dialog_text_secondary"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:maxLines="3"
        android:ellipsize="end" />

    <!-- Button Container - Vertical Stack -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Emergency Call Button (Red) -->
        <LinearLayout
            android:id="@+id/btn_ok"
            android:layout_width="240dp"
            android:layout_height="56dp"
            android:background="@drawable/ok_button_background"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <!-- SOS Circle -->
            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="SOS"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/sos_circle_background"
                android:gravity="center"
                android:layout_marginEnd="12dp" />

            <!-- Emergency Call Text -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EMERGENCY\nCALL"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-2dp"
                android:gravity="start" />

        </LinearLayout>

        <!-- I'm OK Button (Gray) -->
        <LinearLayout
            android:id="@+id/btn_cancel"
            android:layout_width="240dp"
            android:layout_height="48dp"
            android:background="@drawable/ok_button_background"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true">

            <!-- I'm OK Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I'm OK"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="normal"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>