<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_grey"
    android:padding="16dp"
    app:boxedEdges="all">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_boxedEdges="all">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Status Display -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: Ready"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textAlignment="center"
                android:layout_marginBottom="8dp"
                tools:ignore="HardcodedText" />

            <!-- Phone Number Input -->
            <EditText
                android:id="@+id/et_phone_number"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:hint="Phone Number"
                android:textColorHint="@color/light_grey"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:background="@drawable/edittext_background"
                android:padding="8dp"
                android:inputType="phone"
                android:layout_marginBottom="8dp"
                tools:ignore="HardcodedText" />

            <!-- Call Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btn_call"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Call"
                    android:textSize="11sp"
                    android:background="@drawable/call_button_background"
                    android:textColor="@color/white"
                    android:layout_marginEnd="4dp"
                    tools:ignore="HardcodedText" />

                <Button
                    android:id="@+id/btn_hangup"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Hangup"
                    android:textSize="11sp"
                    android:background="@drawable/hangup_button_background"
                    android:textColor="@color/white"
                    android:layout_marginStart="4dp"
                    tools:ignore="HardcodedText" />

            </LinearLayout>

            <!-- Message Input -->
            <EditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:hint="Type message..."
                android:textColorHint="@color/light_grey"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:background="@drawable/edittext_background"
                android:padding="8dp"
                android:inputType="textMultiLine"
                android:maxLines="2"
                android:layout_marginBottom="8dp" />

            <!-- Send Message Button -->
            <Button
                android:id="@+id/btn_send_message"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Send Message"
                android:textSize="11sp"
                android:background="@drawable/message_button_background"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp" />

            <!-- Messages Display -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Messages:"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/messages_background">

                <TextView
                    android:id="@+id/tv_messages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:padding="8dp" />

            </ScrollView>

        </LinearLayout>

    </ScrollView>

</androidx.wear.widget.BoxInsetLayout>