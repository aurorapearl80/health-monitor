<?xml version="1.0" encoding="utf-8"?>
<!-- Use this version for a more focused weight monitoring experience -->

<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#81C784"
    app:boxedEdges="all">

    <androidx.wear.widget.SwipeDismissFrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingLeft="@dimen/watch_inset_horizontal"
            android:paddingRight="@dimen/watch_inset_horizontal"
            android:paddingTop="@dimen/watch_inset_vertical"
            android:paddingBottom="@dimen/watch_inset_vertical"
            android:clipToPadding="false"
            android:scrollbarStyle="outsideInset">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="4dp">

                <!-- Main Weight Display -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!-- Page Title -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tvTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weight Monitor"
                            android:textSize="11sp"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Weight Value with Unit -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tv_value_bg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="32sp"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="@android:color/white"
                            android:layout_marginStart="6dp"
                            android:layout_marginBottom="4dp" />

                    </LinearLayout>

                    <!-- Estimated Body Composition -->
                    <TextView
                        android:id="@+id/tv_body_composition_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Estimated Body Composition"
                        android:textSize="10sp"
                        android:textColor="@android:color/white"
                        android:layout_marginTop="4dp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <!-- Body Composition Row — equal-weight columns filling full width -->
                    <LinearLayout
                        android:id="@+id/bodyCompositionRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <!-- Body Water -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvBodyWater"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="10sp"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BODY WATER"
                                android:textSize="7sp"
                                android:textColor="@android:color/white"
                                android:alpha="0.8"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Lean Mass -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvLeanMass"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="10sp"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LEAN MASS"
                                android:textSize="7sp"
                                android:textColor="@android:color/white"
                                android:alpha="0.8"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Fat Mass -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvFatMass"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="10sp"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FAT MASS"
                                android:textSize="7sp"
                                android:textColor="@android:color/white"
                                android:alpha="0.8"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Body Fat % -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvBodyFatPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="10sp"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BODY FAT %"
                                android:textSize="7sp"
                                android:textColor="@android:color/white"
                                android:alpha="0.8"
                                android:gravity="center" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Time Ago -->
                    <TextView
                        android:id="@+id/tv_time_ago"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="10sp"
                        android:textColor="@android:color/white"
                        android:layout_marginTop="2dp" />

                    <!-- BMI Status -->
                    <TextView
                        android:id="@+id/tvBMIStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="10sp"
                        android:textColor="@android:color/white"
                        android:layout_marginTop="4dp"
                        android:alpha="0.8" />

                </LinearLayout>

                <!-- Status Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvBPM"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BMI: "
                        android:textSize="10sp"
                        android:textColor="@android:color/white"
                        android:layout_marginEnd="8dp"
                        android:gravity="center" />

                    <ImageView
                        android:id="@+id/heartIcon"
                        android:layout_width="18dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_weight_foreground"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/tvOutcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="10sp"
                        android:textColor="@android:color/white"
                        android:gravity="center" />

                    <ImageView
                        android:id="@+id/chartIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_chart"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginLeft="16dp"
                        app:tint="@android:color/white" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/white"
                    android:alpha="0.3"
                    android:layout_marginVertical="@dimen/card_spacing"/>

                <include
                    android:id="@+id/metricsPanel"
                    layout="@layout/layout_metrics_panel" />

                <include layout="@layout/include_quick_actions" />

            </LinearLayout>

        </ScrollView>

    </androidx.wear.widget.SwipeDismissFrameLayout>

    <ImageView
        android:id="@+id/ivConnectionStatus"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="8dp"
        android:contentDescription="Connection status"
        app:tint="@android:color/white"
        android:visibility="invisible" />

</androidx.wear.widget.BoxInsetLayout>
